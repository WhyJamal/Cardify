datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model User {
  id       String  @id @default(cuid())
  name     String?
  email    String  @unique
  password String

  ownedWorkspaces      Workspace[]       @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  boards               Board[]
  notifications        Notification[]
  boardMembers         BoardMember[]
  cardMemberships      CardMember[]
  userTaskActions      UserTaskAction[]
  cardTimelines        CardTimeline[]

  ownedCards           Card[] @relation("CardOwner")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}


model UserTaskAction {
  id        String   @id @default(cuid())
  userId    String
  cardId    String
  status    UserTaskStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, status])
}

enum UserTaskStatus {
  PENDING
  COMPLETED
  DISMISSED
}

enum Visibility {
  PRIVATE
  PUBLIC
  WORKSPACE
}

model Workspace {
  id            String @id @default(cuid())
  name          String
  description   String?
  typeKey       String?
  type          WorkspaceType? @relation(fields: [typeKey], references: [key])
  ownerId       String
  logo          String?
  website       String?
  visibility    Visibility @default(PUBLIC)

  owner         User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       WorkspaceMember[]
  boards        Board[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ownerId])
}

model WorkspaceType {
  id     String @id @default(cuid())
  key    String @unique
  label  String
  group  String?

  workspaces Workspace[]
}

enum WorkspaceMemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum WorkspaceMemberStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model WorkspaceMember {
  id          String                @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceMemberRole   @default(MEMBER)
  status      WorkspaceMemberStatus @default(PENDING)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

enum NotificationType {
  BOARD_INVITE
  BOARD_INVITE_ACCEPTED
  BOARD_INVITE_DECLINED
  WORKSPACE_INVITE
  CARD_ASSIGNED
  // in future: CARD_ASSIGNED, CARD_DUE, COMMENT_MENTION ...
}

model Notification {
  id     String           @id @default(cuid())
  userId String
  type   NotificationType
  title  String
  body   String?

  data String?

  isRead      Boolean @default(false)
  isDismissed Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, isDismissed, createdAt])
}

enum BoardMemberStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum BoardMemberRole {
  OWNER
  MEMBER
  VIEWER
}

model Board {
  id              Int     @id @default(autoincrement())
  title           String
  bg              String
  isPhoto         Boolean @default(true)
  isChoosen       Boolean           @default(false)
  visibility      Visibility @default(PUBLIC)

  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  ownerId         String
  owner           User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  columns         Column[]
  labels          BoardLabel[]
  members         BoardMember[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([workspaceId])
  @@index([ownerId])
}

model BoardMember {
  id      String            @id @default(cuid())
  boardId Int
  userId  String
  role    BoardMemberRole   @default(MEMBER)
  status  BoardMemberStatus @default(PENDING)

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([boardId, userId])
  @@index([boardId])
  @@index([userId])
}

model BoardLabel {
  id        String   @id @default(cuid())
  boardId   Int
  color     String
  name      String?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  board Board            @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardBoardLabel[]

  @@index([boardId])
}

model Column {
  id        String   @id @default(cuid())
  boardId   Int
  title     String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId, position])
}

enum SizeOption {
  WIDE
  TALL
}

model Card {
  id               String           @id @default(cuid())
  columnId         String
  title            String?
  image            String?
  numberBadge      Int?
  description      String?
  hasDescription   Boolean          @default(false)
  watching         Boolean          @default(false)
  checklistDone    Int              @default(0)
  checklistTotal   Int              @default(0)
  assigneeInitials String?
  assigneeColor    String?
  position         Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  dueDate          DateTime?
  isCompleted      Boolean          @default(false)

  isImage          Boolean           @default(false)
  background       String?
  size             SizeOption        @default(WIDE)
  textColor        String?

  isArchive        Boolean           @default(false)
  
  column           Column            @relation(fields: [columnId], references: [id], onDelete: Cascade)
  labels           CardBoardLabel[]
  links            CardLink[]
  comments         CardTimeline[]
  members          CardMember[]
  attachments      CardAttachment[]

  ownerId          String?
  owner            User?    @relation("CardOwner", fields: [ownerId], references: [id])

  userTaskActions  UserTaskAction[]

  @@index([columnId, position])
}

model CardBoardLabel {
  id           String @id @default(cuid())
  cardId       String
  boardLabelId String

  card       Card       @relation(fields: [cardId], references: [id], onDelete: Cascade)
  boardLabel BoardLabel @relation(fields: [boardLabelId], references: [id])

  @@unique([cardId, boardLabelId])
  @@index([cardId, boardLabelId])
}

model CardLink {
  id        String   @id @default(cuid())
  cardId    String
  icon      String?
  text      String
  url       String?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

enum CardTimelineType {
  COMMENT
  ACTIVITY
}

model CardTimeline {
  id           String           @id @default(cuid())
  cardId       String
  userId       String?
  type         CardTimelineType @default(COMMENT)
  authorName   String
  initials     String?
  text         String?
  activityText String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([cardId, createdAt])
  @@index([userId])
}

model CardMember {
  id     String @id @default(cuid())
  cardId String
  userId String

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([cardId, userId])
  @@index([cardId])
  @@index([userId])
}

model CardAttachment {
  id         String   @id @default(cuid())
  cardId     String
  fileName   String
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  uploadedBy String?
  createdAt  DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId])
}
